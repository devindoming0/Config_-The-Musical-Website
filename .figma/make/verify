#!/bin/bash
# Wait for the dev server to be reachable
timeout=30
elapsed=0
until curl -s -o /dev/null -w '' http://localhost:5173; do
  sleep 1
  elapsed=$((elapsed + 1))
  if [ $elapsed -ge $timeout ]; then
    echo "Dev server did not start within ${timeout}s" >&2
    exit 1
  fi
done
echo "Dev server is up at http://localhost:5173"
